# ======================================
# UCE IT — Hostel Management System
# Required:  Supabase URL + Anon Key
# Optional:  Firebase (FCM for push notifications)
# ======================================

# --- Supabase (required) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# --- Firebase (optional — for push notifications) ---
# If left empty, push notifications are disabled.
# In-app notifications still work via Supabase Realtime.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_VAPID_KEY=
